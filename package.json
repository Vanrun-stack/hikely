{
  "name": "hikely",
  "private": true,
  "scripts": {
    "dev": "turbo dev --filter=web",
    "build": "turbo build --filter=web",
    "lint": "turbo lint --filter=web",
    "test": "turbo test --filter=web",
    "type-check": "turbo type-check --filter=web",
    "db:push": "pnpm --filter web prisma db push",
    "db:studio": "pnpm --filter web prisma studio",
    "db:generate": "pnpm --filter web prisma generate",
    "db:seed": "pnpm --filter web prisma db seed",
    "docker:dev": "docker compose up -d",
    "docker:prod": "docker compose -f docker-compose.prod.yml up -d --build",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "start": "pnpm --filter web start"
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.5.0",
    "prettier": "^3.3.0",
    "@types/node": "^22.0.0"
  },
  "engines": {
    "node": ">=22.0.0",
    "pnpm": ">=9.0.0"
  },
  "packageManager": "pnpm@9.0.0"
}
