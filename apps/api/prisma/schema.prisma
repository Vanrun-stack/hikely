// This is your Prisma schema file for Hikely
// Learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions", "driverAdapters"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [uuidOssp(map: "uuid-ossp"), postgis, pgTrgm(map: "pg_trgm"), unaccent]
}

// ─── Enums ───────────────────────────────────────────────────────

enum DifficultyLevel {
  very_easy
  easy
  moderate
  hard
  expert
}

enum HikeType {
  loop
  out_and_back
  point_to_point
}

enum TerrainType {
  trail
  rocky
  snow
  mixed
  via_ferrata
}

enum PracticeType {
  hiking
  trail_running
  snowshoeing
  mountain_biking
  cycling
}

enum HikeStatus {
  draft
  pending_review
  published
  rejected
  archived
}

enum UserRole {
  user
  moderator
  admin
  super_admin
}

enum BadgeType {
  explorer
  contributor
  reviewer
  pioneer
  legend
  seasonal
}

enum ReportReason {
  incorrect_info
  dangerous_conditions
  inappropriate_content
  duplicate
  other
}

enum ReportStatus {
  open
  investigating
  resolved
  dismissed
}

// ─── Models ──────────────────────────────────────────────────────

model User {
  id               String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  email            String    @unique @db.VarChar(255)
  username         String    @unique @db.VarChar(50)
  displayName      String?   @map("display_name") @db.VarChar(100)
  avatarUrl        String?   @map("avatar_url")
  bio              String?
  websiteUrl       String?   @map("website_url")
  location         String?   @db.VarChar(200)
  passwordHash     String?   @map("password_hash")
  role             UserRole  @default(user)
  level            Int       @default(1) @db.SmallInt
  xpPoints         Int       @default(0) @map("xp_points")
  isActive         Boolean   @default(true) @map("is_active")
  isVerified       Boolean   @default(false) @map("is_verified")
  emailVerifiedAt  DateTime? @map("email_verified_at") @db.Timestamptz
  lastLoginAt      DateTime? @map("last_login_at") @db.Timestamptz
  deletedAt        DateTime? @map("deleted_at") @db.Timestamptz
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  oauthAccounts    OAuthAccount[]
  refreshTokens    RefreshToken[]
  hikes            Hike[]
  photos           Photo[]
  reviews          Review[]
  favorites        Favorite[]
  hikeLists        HikeList[]
  followers        Follow[]       @relation("Following")
  following        Follow[]       @relation("Follower")
  badges           UserBadge[]
  reports          Report[]
  auditLogs        AuditLog[]

  @@index([email])
  @@index([username])
  @@map("users")
}

model OAuthAccount {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId      String   @map("user_id") @db.Uuid
  provider    String   @db.VarChar(50)
  providerId  String   @map("provider_id") @db.VarChar(255)
  accessToken String?  @map("access_token")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash")
  userAgent String?   @map("user_agent")
  ipAddress String?   @map("ip_address")
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Region {
  id          String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String   @db.VarChar(200)
  slug        String   @unique @db.VarChar(200)
  country     String   @db.VarChar(100)
  countryCode String   @map("country_code") @db.Char(2)
  description String?
  coverUrl    String?  @map("cover_url")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  hikes       Hike[]

  @@map("regions")
}

model Hike {
  id               String          @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  authorId         String?         @map("author_id") @db.Uuid
  regionId         String?         @map("region_id") @db.Uuid
  name             String          @db.VarChar(300)
  slug             String          @unique @db.VarChar(300)
  description      String?
  status           HikeStatus      @default(draft)
  difficulty       DifficultyLevel @default(moderate)
  hikeType         HikeType        @default(loop) @map("hike_type")
  terrainType      TerrainType     @default(trail) @map("terrain_type")
  practiceType     PracticeType    @default(hiking) @map("practice_type")

  // Stats
  distanceKm       Decimal?        @map("distance_km") @db.Decimal(8, 3)
  elevationGainM   Int?            @map("elevation_gain_m")
  elevationLossM   Int?            @map("elevation_loss_m")
  altitudeMinM     Int?            @map("altitude_min_m")
  altitudeMaxM     Int?            @map("altitude_max_m")
  durationMin      Int?            @map("duration_min")

  // SEO
  metaTitle        String?         @map("meta_title") @db.VarChar(70)
  metaDescription  String?         @map("meta_description") @db.VarChar(160)
  featuredImageUrl String?         @map("featured_image_url")

  // Counters
  viewCount        Int             @default(0) @map("view_count")
  downloadCount    Int             @default(0) @map("download_count")
  avgRating        Decimal         @default(0) @map("avg_rating") @db.Decimal(3, 2)
  reviewCount      Int             @default(0) @map("review_count")
  photoCount       Int             @default(0) @map("photo_count")
  favoriteCount    Int             @default(0) @map("favorite_count")

  // Timestamps
  deletedAt        DateTime?       @map("deleted_at") @db.Timestamptz
  publishedAt      DateTime?       @map("published_at") @db.Timestamptz
  createdAt        DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  author           User?           @relation(fields: [authorId], references: [id])
  region           Region?         @relation(fields: [regionId], references: [id])
  gpxFile          GpxFile?
  photos           Photo[]
  reviews          Review[]
  favorites        Favorite[]
  tags             HikeTag[]
  listItems        HikeListItem[]
  reports          Report[]

  @@index([slug])
  @@index([status])
  @@index([regionId])
  @@map("hikes")
}

model GpxFile {
  id               String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hikeId           String   @unique @map("hike_id") @db.Uuid
  storageKey       String   @map("storage_key")
  originalFilename String?  @map("original_filename")
  fileSizeBytes    Int?     @map("file_size_bytes")
  elevationProfile Json?    @map("elevation_profile")
  waypoints        Json?
  checksum         String?
  processingStatus String   @default("pending") @map("processing_status") @db.VarChar(50)
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz

  hike             Hike     @relation(fields: [hikeId], references: [id], onDelete: Cascade)

  @@map("gpx_files")
}

model Tag {
  id        String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name      String    @unique @db.VarChar(100)
  slug      String    @unique @db.VarChar(100)
  color     String?   @db.VarChar(7)
  icon      String?   @db.VarChar(50)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  hikes     HikeTag[]

  @@map("tags")
}

model HikeTag {
  hikeId String @map("hike_id") @db.Uuid
  tagId  String @map("tag_id") @db.Uuid

  hike   Hike   @relation(fields: [hikeId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([hikeId, tagId])
  @@map("hike_tags")
}

model Photo {
  id          String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hikeId      String    @map("hike_id") @db.Uuid
  authorId    String?   @map("author_id") @db.Uuid
  storageKey  String    @map("storage_key")
  thumbnailKey String?  @map("thumbnail_key")
  caption     String?
  lat         Float?
  lng         Float?
  takenAt     DateTime? @map("taken_at") @db.Timestamptz
  isFeatured  Boolean   @default(false) @map("is_featured")
  sortOrder   Int       @default(0) @map("sort_order") @db.SmallInt
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz

  hike        Hike      @relation(fields: [hikeId], references: [id], onDelete: Cascade)
  author      User?     @relation(fields: [authorId], references: [id])
  reports     Report[]

  @@index([hikeId])
  @@map("photos")
}

model Review {
  id           String    @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  hikeId       String    @map("hike_id") @db.Uuid
  authorId     String    @map("author_id") @db.Uuid
  rating       Int       @db.SmallInt
  content      String?
  visitedAt    DateTime? @map("visited_at") @db.Date
  conditions   String?   @db.VarChar(50)
  isVerified   Boolean   @default(false) @map("is_verified")
  helpfulCount Int       @default(0) @map("helpful_count")
  deletedAt    DateTime? @map("deleted_at") @db.Timestamptz
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  hike         Hike      @relation(fields: [hikeId], references: [id], onDelete: Cascade)
  author       User      @relation(fields: [authorId], references: [id], onDelete: Cascade)
  reports      Report[]

  @@unique([hikeId, authorId])
  @@index([hikeId])
  @@map("reviews")
}

model Favorite {
  userId    String   @map("user_id") @db.Uuid
  hikeId    String   @map("hike_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  hike      Hike     @relation(fields: [hikeId], references: [id], onDelete: Cascade)

  @@id([userId, hikeId])
  @@map("favorites")
}

model HikeList {
  id          String         @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  ownerId     String         @map("owner_id") @db.Uuid
  name        String         @db.VarChar(200)
  description String?
  isPublic    Boolean        @default(true) @map("is_public")
  coverUrl    String?        @map("cover_url")
  createdAt   DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  owner       User           @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  items       HikeListItem[]

  @@map("hike_lists")
}

model HikeListItem {
  listId    String   @map("list_id") @db.Uuid
  hikeId    String   @map("hike_id") @db.Uuid
  sortOrder Int      @default(0) @map("sort_order") @db.SmallInt
  addedAt   DateTime @default(now()) @map("added_at") @db.Timestamptz

  list      HikeList @relation(fields: [listId], references: [id], onDelete: Cascade)
  hike      Hike     @relation(fields: [hikeId], references: [id], onDelete: Cascade)

  @@id([listId, hikeId])
  @@map("hike_list_items")
}

model Follow {
  followerId   String   @map("follower_id") @db.Uuid
  followingId  String   @map("following_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  follower     User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following    User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@id([followerId, followingId])
  @@map("follows")
}

model Badge {
  id          String     @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  name        String     @db.VarChar(100)
  slug        String     @unique @db.VarChar(100)
  description String?
  iconUrl     String?    @map("icon_url")
  badgeType   BadgeType  @map("badge_type")
  xpReward    Int        @default(0) @map("xp_reward")
  isSecret    Boolean    @default(false) @map("is_secret")
  createdAt   DateTime   @default(now()) @map("created_at") @db.Timestamptz

  users       UserBadge[]

  @@map("badges")
}

model UserBadge {
  userId   String   @map("user_id") @db.Uuid
  badgeId  String   @map("badge_id") @db.Uuid
  earnedAt DateTime @default(now()) @map("earned_at") @db.Timestamptz

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge    Badge    @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@id([userId, badgeId])
  @@map("user_badges")
}

model Report {
  id          String       @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  reporterId  String?      @map("reporter_id") @db.Uuid
  hikeId      String?      @map("hike_id") @db.Uuid
  reviewId    String?      @map("review_id") @db.Uuid
  photoId     String?      @map("photo_id") @db.Uuid
  reason      ReportReason
  description String?
  status      ReportStatus @default(open)
  resolvedBy  String?      @map("resolved_by") @db.Uuid
  resolvedAt  DateTime?    @map("resolved_at") @db.Timestamptz
  resolution  String?
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz

  reporter    User?        @relation(fields: [reporterId], references: [id])
  hike        Hike?        @relation(fields: [hikeId], references: [id])
  review      Review?      @relation(fields: [reviewId], references: [id])
  photo       Photo?       @relation(fields: [photoId], references: [id])

  @@map("reports")
}

model AuditLog {
  id        String   @id @default(dbgenerated("uuid_generate_v4()")) @db.Uuid
  userId    String?  @map("user_id") @db.Uuid
  action    String   @db.VarChar(100)
  tableName String?  @map("table_name") @db.VarChar(100)
  recordId  String?  @map("record_id") @db.Uuid
  oldData   Json?    @map("old_data")
  newData   Json?    @map("new_data")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user      User?    @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([tableName, recordId])
  @@map("audit_logs")
}
