# ─── Git Line Endings ────────────────────────────────────────────
* text=auto eol=lf

# Force LF for shell scripts
*.sh text eol=lf

# Preserve binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary
*.woff binary
*.woff2 binary
*.ttf binary
*.eot binary
*.pdf binary
*.zip binary
