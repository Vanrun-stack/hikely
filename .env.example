# ═══════════════════════════════════════════════════════════════════
#  HIKELY — Environment Variables
#  Copy this file to .env and fill in the values
#  cp .env.example .env
# ═══════════════════════════════════════════════════════════════════

# ─── App ──────────────────────────────────────────────────────────
NODE_ENV=development

# ─── Database (PostgreSQL + PostGIS) ──────────────────────────────
DATABASE_URL=postgresql://hikely:password@localhost:5432/hikely
POSTGRES_PASSWORD=password

# ─── NextAuth ─────────────────────────────────────────────────────
# Generate a secret: openssl rand -base64 32
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-super-secret-key-minimum-32-chars

# ─── OAuth (Optional) ────────────────────────────────────────────
# Get credentials from https://console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Get credentials from https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# ─── Email / SMTP (Optional) ─────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@hikely.app

# ─── Sentry (Optional — production only) ─────────────────────────
SENTRY_DSN=

# ─── Next.js Public ──────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAPLIBRE_STYLE=https://demotiles.maplibre.org/style.json

# ─── Docker Compose Overrides ────────────────────────────────────
APP_PORT=3000
DB_PORT=5432
